-- Toggle TP
local function toggleTP()
    tpEnabled = not tpEnabled
    if tpEnabled then
        bToggleTP.Text = "  TP ON STEAL: ON"
        TweenService:Create(iStatus, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(0, 255, 230)}):Play()
        createNotification("Cloud Hub", "Auto TP enabled! Will teleport on steal.", 3, false)
    else
        bToggleTP.Text = "  TP ON STEAL: OFF"
        TweenService:Create(iStatus, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(255, 60, 60)}):Play()
        createNotification("Cloud Hub", "Auto TP disabled.", 2, false)
    end
end

