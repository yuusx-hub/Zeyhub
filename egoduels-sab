	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, -lblX, 1, 0); lbl.Position = UDim2.new(0, lblX, 0, 0)
	lbl.BackgroundTransparency = 1; lbl.Text = text; lbl.TextColor3 = GREY
	lbl.TextSize = 20; lbl.Font = Enum.Font.Fantasy
	lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.TextWrapped = true; lbl.Parent = row

	local function toggle()
		cfg[key] = not cfg[key]
		icon.Text = cfg[key] and "●" or "○"
		if cb then cb(cfg[key]) end
	end

	local hit = Instance.new("TextButton")
	hit.Size = UDim2.new(1, 0, 1, 0); hit.BackgroundTransparency = 1
	hit.Text = ""; hit.ZIndex = 6; hit.Parent = row
	hit.MouseButton1Click:Connect(toggle)

	if hasKey then
		local k = bind:match("%[(%a)%]") or bind:match("(%a)")
		if k then
			UIS.InputBegan:Connect(function(input, gp)
				if not gp and input.KeyCode == Enum.KeyCode[k:upper()] then toggle() end
			end)
		end
	end
	return row
end

